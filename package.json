{
  "name": "proyecto-cypress-pom",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:headed": "cypress run --headed",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:firefox": "cypress run --browser firefox",
    "report:generate": "node scripts/merge-reports.js",
    "report:merge": "npx mochawesome-merge \"cypress/reports/mochawesome/mochawesome*.json\" -o cypress/reports/mochawesome/report.json",
    "report:clean": "rimraf cypress/reports/mochawesome",
    "test:report": "npm run report:clean && npm run cy:run && npm run report:merge && npm run report:generate"
  },
  "devDependencies": {
    "cypress": "^15.11.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
